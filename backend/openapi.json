      "CharacterSummary": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Character display name"
          },
          "profession": {
            "type": "string",
            "title": "Profession",
            "description": "Character class or profession"
          },
          "level": {
            "type": "integer",
            "title": "Level",
            "description": "Character level"
          },
          "health": {
            "type": "number",
