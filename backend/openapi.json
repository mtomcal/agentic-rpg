          },
          "status_effects": {
            "items": {
              "$ref": "#/components/schemas/StatusEffect"
            },
            "type": "array",
            "title": "Status Effects",
            "description": "Active status effects"
          },
          "level": {
            "type": "integer",
            "minimum": 1.0,
            "title": "Level",
            "description": "Character level",
            "default": 1
          },
          "experience": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Experience",
            "description": "Experience points",
            "default": 0
