          "fixed",
          "flexible",
          "optional"
        ],
        "title": "BeatFlexibility",
        "description": "How much a beat can change."
      },
      "BeatStatus": {
        "type": "string",
        "enum": [
          "planned",
          "active",
          "resolved",
          "skipped",
          "adapted"
        ],
        "title": "BeatStatus",
        "description": "Lifecycle status of a story beat."
      },
      "BeatSummary": {
        "properties": {
          "summary": {
            "type": "string",
            "title": "Summary",
