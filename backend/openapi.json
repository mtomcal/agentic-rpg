  "components": {
    "schemas": {
      "AdaptationRecord": {
        "properties": {
          "reason": {
            "type": "string",
            "title": "Reason",
            "description": "Why the outline was adapted"
          },
          "changes": {
            "type": "string",
            "title": "Changes",
            "description": "What changed in the outline"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "description": "When the adaptation occurred"
          }
        },
        "type": "object",
        "required": [
          "reason",
          "changes"
        ],
        "title": "AdaptationRecord",
        "description": "Record of a story outline adaptation."
      },
