# =============================================================================
# Agentic RPG — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically from the project root.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend → Backend connection URLs
# -----------------------------------------------------------------------------
# These tell the browser where to reach the backend API and WebSocket.
# For local development, use localhost. For remote access (e.g. Tailscale),
# use your machine's hostname or IP.
#
# Examples:
#   Local:     http://localhost:8080 / ws://localhost:8080
#   Tailscale: http://my-host.tail1234.ts.net:8080 / ws://my-host.tail1234.ts.net:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# -----------------------------------------------------------------------------
# Anthropic API Key
# -----------------------------------------------------------------------------
# Required for LLM-powered game interactions (story generation, agent responses).
# Get your key at: https://console.anthropic.com/settings/keys
# Leave blank to start the server without LLM features (useful for UI development).
ANTHROPIC_API_KEY=
